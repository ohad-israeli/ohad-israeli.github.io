---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/lightbox.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const {
  title,
  description = 'Ohad Israeli — projects in data streaming, Kafka, and distributed systems.',
  wide = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Ohad Israeli — projects" href="/rss.xml" />

    <!-- Set theme before paint to avoid a flash of the wrong theme -->
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('theme');
          if (saved === 'light' || saved === 'dark') {
            document.documentElement.setAttribute('data-theme', saved);
          }
        } catch (e) {}
      })();
    </script>

    <!-- Type system: IBM Plex Mono (UI/headings, terminal voice) +
         Newsreader (an elegant serif for reading — a deliberate "field notes"
         contrast against the mono chrome). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main>
      <div class={wide ? 'container wide' : 'container'}>
        <slot />
      </div>
    </main>
    <Footer />

    <!-- Click article images to open a full-viewport, readable view. -->
    <script is:inline>
      (() => {
        const imgs = document.querySelectorAll('.prose figure img, .prose > img, .prose p > img');
        if (!imgs.length) return;
        let overlay;
        const close = () => {
          if (!overlay) return;
          overlay.classList.remove('is-open');
          const o = overlay;
          setTimeout(() => o.remove(), 180);
          overlay = null;
          document.removeEventListener('keydown', onKey);
        };
        const onKey = (e) => { if (e.key === 'Escape') close(); };
        const open = (src, alt) => {
          overlay = document.createElement('div');
          overlay.className = 'lightbox-overlay';
          overlay.innerHTML =
            '<span class="lightbox-hint">esc / click to close</span>' +
            '<img src="' + src + '" alt="' + (alt || '') + '" />' +
            (alt ? '<p class="lightbox-caption"></p>' : '');
          if (alt) overlay.querySelector('.lightbox-caption').textContent = alt;
          overlay.addEventListener('click', close);
          document.body.appendChild(overlay);
          requestAnimationFrame(() => overlay.classList.add('is-open'));
          document.addEventListener('keydown', onKey);
        };
        imgs.forEach((img) => {
          img.setAttribute('loading', 'lazy');
          img.addEventListener('click', () => open(img.currentSrc || img.src, img.alt));
        });
      })();
    </script>
  </body>
</html>
