<mxfile host="app.diagrams.net" type="device">
  <diagram name="onprem-cc-rds" id="onprem-cc-rds">
    <mxGraphModel dx="1300" dy="720" grid="1" gridSize="10" guides="1" connect="1" arrows="1" page="1" pageWidth="1160" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Editable source for /diagrams/debezium-onprem-to-rds.svg.
             Layout: on-prem (left) ; Confluent Cloud (top-right) ; AWS (bottom-right).
             Confluent has no built-in draw.io stencil; the zone is labeled. -->

        <!-- ZONES -->
        <mxCell id="zOnprem" value="On-premises data center" style="sketch=0;outlineConnect=0;html=1;whiteSpace=wrap;fontSize=13;container=0;pointerEvents=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_corporate_data_center;strokeColor=#7D8998;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#5A6C86;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="320" height="470" as="geometry"/>
        </mxCell>
        <mxCell id="zCC" value="Confluent Cloud  (Kafka · Schema Registry · Console UI)" style="rounded=1;arcSize=6;html=1;whiteSpace=wrap;strokeColor=#0B5FFF;fillColor=#F2F6FF;verticalAlign=top;align=left;spacingLeft=14;spacingTop=10;fontColor=#0B5FFF;fontSize=13;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="440" y="80" width="620" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="zAWS" value="AWS Cloud" style="sketch=0;outlineConnect=0;html=1;whiteSpace=wrap;fontSize=13;container=0;pointerEvents=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud;strokeColor=#232F3E;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="440" y="320" width="620" height="210" as="geometry"/>
        </mxCell>

        <!-- ON-PREM nodes -->
        <mxCell id="src" value="SQL Server&#10;source · CDC" style="image;aspect=fixed;perimeter=ellipsePerimeter;html=1;align=center;verticalLabelPosition=bottom;verticalAlign=top;shadow=0;dashed=0;spacingTop=3;image=img/lib/active_directory/sql_server.svg;" vertex="1" parent="1">
          <mxGeometry x="170" y="140" width="58" height="74" as="geometry"/>
        </mxCell>
        <mxCell id="connect" value="Kafka Connect (self-managed)&#10;&#10;• Debezium SQL Server source&#10;• Debezium JDBC sink" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=center;verticalAlign=middle;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="360" width="280" height="150" as="geometry"/>
        </mxCell>

        <!-- CONFLUENT CLOUD nodes -->
        <mxCell id="kafka" value="Kafka cluster" style="points=[];aspect=fixed;html=1;align=center;verticalLabelPosition=bottom;verticalAlign=top;shadow=0;dashed=0;fillColor=#0B5FFF;strokeColor=none;shape=mxgraph.alibaba_cloud.kafka;" vertex="1" parent="1">
          <mxGeometry x="486" y="150" width="76" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="sr" value="Schema Registry&#10;Stream Governance · Avro" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#0B5FFF;fontColor=#0B5FFF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="140" width="360" height="70" as="geometry"/>
        </mxCell>

        <!-- AWS nodes -->
        <mxCell id="dx" value="AWS Direct Connect" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.direct_connect;" vertex="1" parent="1">
          <mxGeometry x="500" y="395" width="70" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="rds" value="Amazon RDS&#10;for SQL Server (target)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#C925D1;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.rds_sql_server_instance;" vertex="1" parent="1">
          <mxGeometry x="840" y="390" width="78" height="78" as="geometry"/>
        </mxCell>

        <!-- EDGES -->
        <mxCell id="e1" value="CDC capture" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#5A6C86;fontColor=#5A6C86;" edge="1" parent="1" source="src" target="connect">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="produce / consume&#10;SASL_SSL · Avro" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;startArrow=classic;endArrow=classic;strokeColor=#0B5FFF;fontColor=#0B5FFF;" edge="1" parent="1" source="connect" target="kafka">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8C4FFF;" edge="1" parent="1" source="connect" target="dx">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="upsert + IDENTITY_INSERT" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#8C4FFF;fontColor=#232F3E;" edge="1" parent="1" source="dx" target="rds">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
